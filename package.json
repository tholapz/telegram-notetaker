{
  "name": "telegram-notetaker",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --define \"APP_VERSION:'$npm_package_version'\" --define \"BUILD_TIME:'$(date -u +%Y-%m-%dT%H:%M:%SZ)'\"",
    "db:init": "wrangler d1 execute telegram-notetaker --file=schema.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "semantic-release": "^25.0.3",
    "typescript": "^5.5.0",
    "wrangler": "^4.86.0"
  }
}
